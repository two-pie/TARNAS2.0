<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<BorderPane prefHeight="420.0" prefWidth="720.0"
            stylesheets="@../css/home.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="it.unicam.cs.bdslab.tarnas.view.SetupController">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>
    <top>
        <VBox spacing="8.0" BorderPane.alignment="CENTER_LEFT">
            <Label text="Setup"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;" />
            <Label text="Select the shared folder to mount in Docker containers." />
        </VBox>
    </top>
    <center>
        <VBox spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="20.0" />
            </padding>
            <VBox spacing="6.0">
                <Label text="Shared folder path"
                       style="-fx-font-weight: bold;" />
                <TextArea fx:id="sharedDirectoryTextArea"
                          editable="false"
                          prefHeight="120.0"
                          prefWidth="640.0"
                          promptText="No folder selected yet"
                          wrapText="false" />
            </VBox>
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
                <Button mnemonicParsing="false"
                        onAction="#handleBrowseButtonAction"
                        text="Browse" />
                <Button mnemonicParsing="false"
                        defaultButton="true"
                        onAction="#handleNextButtonAction"
                        text="Next" />
            </HBox>
        </VBox>
    </center>
    <bottom>
        <Label text="The selected folder will be mounted in the containers as /data."
               style="-fx-font-size: 11px;"
               BorderPane.alignment="CENTER_LEFT">
            <BorderPane.margin>
                <Insets top="12.0" />
            </BorderPane.margin>
        </Label>
    </bottom>
</BorderPane>
